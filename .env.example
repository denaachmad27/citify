# ?? JANGAN ISI NILAI ASLI DI FILE INI!
# File ini hanya sebagai template — copy ke .env.local dan isi di sana.
# .env.local sudah di-ignore oleh .gitignore (tidak akan ke-commit).

# Database (PostgreSQL via Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/citify"

# NextAuth.js
NEXTAUTH_SECRET="generate-dengan-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (NextAuth provider)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxxxxxx"

# Midtrans Payment Gateway (opsional untuk MVP)
MIDTRANS_SERVER_KEY="SB-Mid-server-xxxxxxxxxxxx"

# Cloudflare Workers (opsional — untuk scraping URL via edge)
# CF_API_TOKEN="" 
# CF_ACCOUNT_ID="" 
